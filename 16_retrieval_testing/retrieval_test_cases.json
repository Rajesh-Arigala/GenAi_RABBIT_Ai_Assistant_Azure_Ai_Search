      "expected_page_ids": ["03_02_AI_Project_Azure_MLOps_Platform", "03_02_01_AI_Project_Azure_Module_01", "03_02_02_AI_Project_Azure_Module_02", "03_02_03_AI_Project_Azure_Module_03"],
      "expected_signals": ["Azure", "MLOps", "Module"]
