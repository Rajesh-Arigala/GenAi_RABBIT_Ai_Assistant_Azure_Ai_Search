      "intent": "General production ML deployment retrieval",
      "expected_signals": ["CI/CD", "deployment", "Kubernetes", "MLOps", "pipeline"]
    },
    {
      "id": "sensitivity_005_recruiter_summary",
      "category": "sensitivity_test",
