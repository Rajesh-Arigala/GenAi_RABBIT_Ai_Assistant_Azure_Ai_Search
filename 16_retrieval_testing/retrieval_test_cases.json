      "intent": "Broad business profile retrieval",
      "expected_signals": ["BPCL", "Medtronic", "SMAAT", "R-Cafe", "business leadership"]
    },
    {
      "id": "sensitivity_002_technical_capabilities",
      "category": "sensitivity_test",
      "question": "What technical and cloud capabilities are shown in this portfolio?",
      "intent": "Broad technical capability retrieval",
      "expected_signals": ["AWS", "Azure", "GCP", "Docker", "Kubernetes", "MLflow"]
    },
    {
      "id": "sensitivity_003_ai_platform_work",
      "category": "sensitivity_test",
      "question": "What kind of AI platform engineering work has Rajesh built?",
      "intent": "Broad AI platform retrieval",
      "expected_signals": ["MLOps", "Azure", "AWS", "GCP", "Kubeflow", "MLflow"]
    },
    {
      "id": "sensitivity_004_deployment_work",
      "category": "sensitivity_test",
