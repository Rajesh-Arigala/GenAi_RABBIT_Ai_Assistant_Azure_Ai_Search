    {
      "id": "specificity_004_cicd",
      "category": "specificity_test",
      "question": "Which pages discuss CI/CD pipelines?",
      "intent": "Specific CI/CD section retrieval",
      "expected_page_id_contains": ["CICD"],
      "expected_signals": ["CI/CD", "pipeline", "GitHub Actions", "Azure DevOps"]
